# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

############################################
# Bundler
############################################
/.bundle

############################################
# Environment & Secrets
############################################
/.env*
!/.env*.erb
.env.local
.env.*.local
/config/master.key
/config/credentials/*.key

############################################
# Logs & Temp files
############################################
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# PIDs
/tmp/pids/*
!/tmp/pids/
/tmp/pids/.keep

# Cache & storage
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
/tmp/storage/.keep

############################################
# Assets
############################################
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Precompiled JS/CSS (esbuild, webpack, vite, etc.)
/node_modules
/yarn-error.log
/npm-debug.log*
/pnpm-debug.log*
/package-lock.json
/pnpm-lock.yaml

############################################
# Coverage / Testing
############################################
/coverage/
/spec/examples.txt
/spec/tmp
/test/tmp

############################################
# Byebug / Pry / IRB
############################################
.byebug_history
.irb_history
.pry_history

############################################
# Editor / IDE Specific
############################################
*.swp
*~
.project
.idea
.vscode
*.sublime-project
*.sublime-workspace

############################################
# System Files
############################################
.DS_Store
Thumbs.db

############################################
# Docker / CI
############################################
/.dockerignore
/docker-compose.override.yml
