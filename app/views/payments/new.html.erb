<h2 class="text-2xl font-bold mb-4">Add Payment for <%= @tenant.full_name %> - <%= @rent.month %></h2>
<%= form_with model: [@tenant, @rent, @payment], local: true do |f| %>
  <div class="mb-4">
    <%= f.label :amount, class: 'block font-semibold' %>
    <%= f.number_field :amount, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :payment_date, class: 'block font-semibold' %>
    <%= f.date_field :payment_date, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :payment_mode, class: 'block font-semibold' %>
    <%= f.select :payment_mode, Payment::PAYMENT_MODES, {}, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :transaction_id, class: 'block font-semibold' %>
    <%= f.text_field :transaction_id, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :note, class: 'block font-semibold' %>
    <%= f.text_field :note, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <%= f.submit 'Add Payment', class: 'bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700' %>
<% end %>
