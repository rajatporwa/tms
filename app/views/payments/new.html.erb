<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Rents", path: house_house_room_tenant_rents_path(@house, @house_room, @tenant) },
    { name: @rent.month, path: house_house_room_tenant_rent_path(@house, @house_room, @tenant, @rent) },
    { name: "Add Payment" }
  ]) %>
<% end %>

<h2 class="text-2xl font-bold mb-4">Add Payment &mdash; <%= @tenant.full_name %> / <%= @rent.month %></h2>
<%= form_with model: [@house, @house_room, @tenant, @rent, @payment], local: true do |f| %>
  <div class="mb-4">
    <%= f.label :amount, class: 'block font-semibold' %>
    <%= f.number_field :amount, step: '0.01', class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :payment_date, class: 'block font-semibold' %>
    <%= f.date_field :payment_date, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :payment_mode, class: 'block font-semibold' %>
    <%= f.select :payment_mode, Payment::PAYMENT_MODES, {}, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :transaction_id, class: 'block font-semibold' %>
    <%= f.text_field :transaction_id, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :note, class: 'block font-semibold' %>
    <%= f.text_field :note, class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="flex gap-3">
    <%= f.submit 'Add Payment', class: 'bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 cursor-pointer' %>
    <%= link_to "Cancel", house_house_room_tenant_rent_path(@house, @house_room, @tenant, @rent), class: "border px-4 py-2 rounded text-gray-600 hover:bg-gray-50" %>
  </div>
<% end %>
