<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h2 class="text-3xl font-bold text-gray-900">Your Houses</h2>
      <p class="text-gray-500 mt-1">Manage all your properties and rooms in one place.</p>
    </div>
    <%= link_to new_house_path, class: "inline-flex items-center bg-blue-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-blue-700 transition-colors shadow-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" style="width: 20px; height: 20px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add New House
    <% end %>
  </div>

  <% if @houses.empty? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center max-w-2xl mx-auto mt-12">
      <div class="bg-blue-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-blue-500" style="width: 40px; height: 40px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">No houses added yet</h3>
      <p class="text-gray-500 mb-8 text-lg">Get started by creating your first property to manage tenants and rooms.</p>
      <%= link_to "Add Your First House", new_house_path, class: "inline-block bg-blue-600 text-white px-8 py-3.5 rounded-xl font-semibold hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      <% @houses.each do |house| %>
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg border border-gray-100 overflow-hidden transition-all duration-300 flex flex-col group">
          <%= link_to house_path(house), class: "block relative aspect-[4/3] overflow-hidden bg-gray-100" do %>
            <% if house.house_images.attached? && house.house_images.first&.variable? %>
              <%= image_tag house.house_images.first.variant(resize_to_fill: [800, 600]), class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              <% if house.house_images.count > 1 %>
                <div class="absolute bottom-3 right-3 bg-black/70 backdrop-blur-md text-white text-xs font-semibold px-2.5 py-1.5 rounded-lg shadow-sm">
                  +<%= house.house_images.count - 1 %> Photos
                </div>
              <% end %>
            <% else %>
              <div class="w-full h-full min-h-[200px] flex flex-col items-center justify-center text-gray-400 bg-gray-50">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-3 opacity-30" style="width: 64px; height: 64px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span class="text-sm font-medium">No Image Available</span>
              </div>
            <% end %>
            
            <div class="absolute top-3 left-3 flex gap-2">
              <span class="bg-blue-600/90 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 rounded-lg shadow-sm">
                <%= house.no_of_rooms || 0 %> Rooms
              </span>
            </div>
          <% end %>
          
          <div class="p-6 flex-1 flex flex-col">
            <%= link_to house_path(house), class: "group-hover:text-blue-600 transition-colors inline-block mb-3" do %>
              <h3 class="text-xl font-bold text-gray-900 leading-tight line-clamp-1" title="<%= house.house_name %>"><%= house.house_name %></h3>
            <% end %>
            
            <div class="space-y-3 mb-6 flex-1 mt-4">
              <div class="flex items-start text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2.5 mt-0.5 text-gray-400 shrink-0" style="width: 20px; height: 20px; flex-shrink: 0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <p class="line-clamp-2 leading-relaxed" title="<%= house.address %>"><%= house.address %></p>
              </div>
              
              <div class="flex items-center text-sm text-gray-600 pt-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2.5 text-gray-400" style="width: 20px; height: 20px; flex-shrink: 0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <p class="truncate font-medium">Owner: <%= house.owner_name.presence || 'Self' %></p>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-3 pt-5 border-t border-gray-100 mt-auto">
              <%= link_to edit_house_path(house), class: "flex items-center justify-center text-gray-700 bg-gray-50 hover:bg-blue-50 hover:text-blue-700 font-medium text-sm transition-all py-2.5 px-3 rounded-lg border border-gray-200 hover:border-blue-200" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit
              <% end %>
              
              <%= button_to house_path(house), 
                  method: :delete, 
                  form: { data: { turbo_confirm: "Are you sure you want to permanently delete '#{house.house_name}' and all of its rooms?" }, class: "w-full" }, 
                  class: "w-full flex items-center justify-center text-red-600 bg-red-50 hover:bg-red-600 hover:text-white font-medium text-sm transition-all py-2.5 px-3 rounded-lg border border-red-100 cursor-pointer" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Delete
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
