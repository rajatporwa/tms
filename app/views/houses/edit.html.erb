<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Edit" }
  ]) %>
<% end %>

<div class="max-w-2xl mx-auto mb-6 px-4 sm:px-0">
  <h2 class="text-3xl font-bold text-gray-900">Edit <%= @house.house_name %></h2>
  <p class="text-gray-600 mt-2 text-lg">Update the details for this property.</p>
</div>

<%= render 'form', house: @house %>
