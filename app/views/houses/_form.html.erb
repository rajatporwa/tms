<%= form_with model: house, class: "max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-md border border-gray-100" do |f| %>
  <% if house.errors.any? %>
    <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg">
      <h3 class="font-bold"><%= pluralize(house.errors.count, "error") %> prohibited this house from being saved:</h3>
      <ul class="list-disc ml-5 mt-2 text-sm">
        <% house.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-5">
    <%= f.label :house_name, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :house_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all", placeholder: "e.g. My Awesome Villa", required: true %>
  </div>

  <div class="mb-5">
    <%= f.label :address, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_area :address, rows: 3, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all", placeholder: "Complete address of the house", required: true %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
    <div>
      <%= f.label :owner_name, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :owner_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all", placeholder: "Name of the owner" %>
    </div>

    <div>
      <%= f.label :no_of_rooms, "Total Rooms", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.number_field :no_of_rooms, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all", min: 1, placeholder: "e.g. 5" %>
    </div>
  </div>

  <div class="mb-8 p-5 bg-gray-50 border border-gray-200 rounded-lg">
    <%= f.label :house_images, "Upload House Images", class: "block text-sm font-semibold text-gray-900 mb-2" %>
    <p class="text-xs text-gray-500 mb-3">You can upload multiple high-quality images of the house.</p>
    <%= f.file_field :house_images, multiple: true, class: "block w-full text-sm text-gray-600 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-blue-700 file:cursor-pointer cursor-pointer transition-all border border-gray-300 bg-white rounded-lg file:transition-colors" %>
    
    <% if house.house_images.attached? %>
      <div class="mt-5 border-t border-gray-200 pt-4">
        <p class="text-sm font-medium text-gray-700 mb-3">Currently Uploaded Images:</p>
        <div class="flex flex-wrap gap-3">
          <% house.house_images.each do |image| %>
            <% if image.variable? %>
              <div class="relative w-24 h-24 rounded-lg overflow-hidden border border-gray-200 shadow-sm group">
                <%= image_tag image.variant(resize_to_fill: [200, 200]), class: "object-cover w-full h-full group-hover:scale-110 transition-transform duration-300" %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex justify-end items-center pt-5 border-t border-gray-100 gap-3">
    <%= link_to "Cancel", houses_path, class: "px-6 py-2.5 bg-white border border-gray-300 text-gray-700 font-medium rounded-lg shadow-sm hover:bg-gray-50 transition-colors" %>
    <%= f.submit class: "px-6 py-2.5 bg-blue-600 text-white font-medium rounded-lg shadow-sm hover:bg-blue-700 cursor-pointer transition-colors border border-transparent" %>
  </div>
<% end %>
