<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: "New House" }
  ]) %>
<% end %>

<div class="max-w-2xl mx-auto mb-6 px-4 sm:px-0">
  <h2 class="text-3xl font-bold text-gray-900">Add New House</h2>
  <p class="text-gray-600 mt-2 text-lg">Fill in the details below to register a new property in the system.</p>
</div>

<%= render 'form', house: @house %>
