<div class="min-h-[85vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-gray-50/50">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex justify-center">
      <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-600/30 transform -rotate-6 transition-transform hover:rotate-0 duration-300">
        <span class="text-3xl font-extrabold text-white transform rotate-6 hover:rotate-0 transition-transform duration-300">T</span>
      </div>
    </div>
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 tracking-tight">
      Create your account
    </h2>
    <p class="mt-2 text-center text-sm text-gray-600">
      Join TMS to easily manage your tenants and rooms
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-xl shadow-gray-200/50 sm:rounded-2xl sm:px-10 border border-gray-100">
      <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), local: true, class: "space-y-5" do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :firstname, "First Name", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.text_field :firstname, required: true, autofocus: true, class: "appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors" %>
            </div>
          </div>
          <div>
            <%= f.label :lastname, "Last Name", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.text_field :lastname, required: true, class: "appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors" %>
            </div>
          </div>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= f.email_field :email, required: true, autocomplete: "email", class: "appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors" %>
          </div>
        </div>

        <div>
           <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
           <div class="mt-1">
             <%= f.password_field :password, required: true, autocomplete: "new-password", class: "appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors" %>
           </div>
        </div>

        <div>
           <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700" %>
           <div class="mt-1">
             <%= f.password_field :password_confirmation, required: true, class: "appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors" %>
           </div>
        </div>

        <div>
          <%= f.submit "Create Account", class: "w-full flex justify-center py-3 px-4 mt-2 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-3 bg-white text-gray-500 font-medium">
              Already have an account?
            </span>
          </div>
        </div>

        <div class="mt-6">
          <%= link_to "Sign in instead", new_user_session_path, class: "w-full flex justify-center py-3 px-4 border border-gray-300 rounded-xl shadow-sm text-sm font-medium text-blue-600 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>
