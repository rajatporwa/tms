<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Monthly Bills", path: house_house_room_tenant_monthly_bills_path(@house, @house_room, @tenant) },
    { name: "#{Date::MONTHNAMES[@monthly_bill.month]} #{@monthly_bill.year}", path: house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant, @monthly_bill) },
    { name: "Add Payment" }
  ]) %>
<% end %>

<div class="max-w-xl mx-auto py-8">
  <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-200">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Record Payment</h2>

    <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-blue-700">
            Current Outstanding for this bill: <strong>₹<%= @monthly_bill.total_amount.to_f - @monthly_bill.paid_amount.to_f %></strong>
          </p>
        </div>
      </div>
    </div>

    <%= form_with(model: [@house, @house_room, @tenant, @monthly_bill, @payment], url: house_house_room_tenant_monthly_bill_payments_path(@house, @house_room, @tenant, @monthly_bill), local: true, class: "space-y-6") do |f| %>
      
      <% if @payment.errors.any? %>
        <div class="bg-red-50 border border-red-200 p-4 rounded-xl mb-6">
          <h2 class="text-red-700 font-bold mb-2"><%= pluralize(@payment.errors.count, "error") %> prohibited this payment from being saved:</h2>
          <ul class="list-disc list-inside text-red-600 text-sm">
            <% @payment.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :amount, "Amount (₹)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :amount, step: 0.01, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3", placeholder: "e.g., 5000", required: true %>
      </div>

      <div class="grid grid-cols-2 gap-6">
        <div>
          <%= f.label :payment_date, "Date of Payment", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :payment_date, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-3", required: true %>
        </div>
        
        <div>
          <%= f.label :payment_mode, "Mode", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :payment_mode, Payment::PAYMENT_MODES, { prompt: "Select Mode" }, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-3", required: true %>
        </div>
      </div>

      <div>
        <%= f.label :transaction_id, "Transaction ID (Optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :transaction_id, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-3", placeholder: "e.g., UTR, Ref No." %>
      </div>

      <div>
        <%= f.label :note, "Note (Optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :note, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "Any extra details..." %>
      </div>

      <div class="pt-4 flex justify-end gap-3">
        <%= link_to 'Cancel', house_house_room_path(@house, @house_room), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
        <%= f.submit "Save Payment", class: "inline-flex items-center px-6 py-2 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
