<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Rents", path: house_house_room_tenant_rents_path(@house, @house_room, @tenant) },
    { name: "New" }
  ]) %>
<% end %>

<h2 class="text-2xl font-bold mb-4">Add Rent Record &mdash; <%= @tenant.full_name %></h2>
<%= form_with model: [@house, @house_room, @tenant, @rent], local: true do |f| %>
  <div class="mb-4">
    <%= f.label :month, "Month (e.g. March 2026)", class: 'block font-semibold' %>
    <%= f.text_field :month, placeholder: "March 2026", class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :rent_amount, class: 'block font-semibold' %>
    <%= f.number_field :rent_amount, step: '0.01', class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :electricity_share, class: 'block font-semibold' %>
    <%= f.number_field :electricity_share, step: '0.01', class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="mb-4">
    <%= f.label :paid_amount, class: 'block font-semibold' %>
    <%= f.number_field :paid_amount, step: '0.01', class: 'w-full border border-gray-300 rounded px-3 py-2' %>
  </div>
  <div class="flex gap-3">
    <%= f.submit 'Create Rent', class: 'bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 cursor-pointer' %>
    <%= link_to "Cancel", house_house_room_tenant_rents_path(@house, @house_room, @tenant), class: "border px-4 py-2 rounded text-gray-600 hover:bg-gray-50" %>
  </div>
<% end %>
