<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Rents" }
  ]) %>
<% end %>

<div class="max-w-4xl mx-auto mt-6">
  <div class="flex justify-between items-center mb-4">
    <div>
      <h2 class="text-2xl font-bold">Rent Records &mdash; <%= @tenant.full_name %></h2>
      <p class="text-gray-500">Room <%= @house_room.room_number %>, <%= @house.house_name %></p>
    </div>
    <%= link_to 'Add New Rent', new_house_house_room_tenant_rent_path(@house, @house_room, @tenant),
          class: 'bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700' %>
  </div>

  <% if @rents.any? %>
    <table class="min-w-full bg-white rounded-xl shadow divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-sm font-semibold">Month</th>
          <th class="px-4 py-3 text-right text-sm font-semibold">Rent</th>
          <th class="px-4 py-3 text-right text-sm font-semibold">Electricity</th>
          <th class="px-4 py-3 text-right text-sm font-semibold">Total</th>
          <th class="px-4 py-3 text-right text-sm font-semibold">Paid</th>
          <th class="px-4 py-3 text-right text-sm font-semibold">Due</th>
          <th class="px-4 py-3 text-center text-sm font-semibold">Status</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @rents.each do |rent| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= rent.month %></td>
            <td class="px-4 py-3 text-right">&#8377;<%= rent.rent_amount %></td>
            <td class="px-4 py-3 text-right">&#8377;<%= rent.electricity_share %></td>
            <td class="px-4 py-3 text-right font-semibold">&#8377;<%= rent.total_amount %></td>
            <td class="px-4 py-3 text-right text-green-600">&#8377;<%= rent.paid_amount %></td>
            <td class="px-4 py-3 text-right text-red-600 font-semibold">&#8377;<%= rent.due_amount %></td>
            <td class="px-4 py-3 text-center">
              <span class="px-2 py-1 rounded text-xs font-semibold
                <%= rent.status == 'paid' ? 'bg-green-100 text-green-700' : rent.status == 'partial' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
                <%= rent.status.capitalize %>
              </span>
            </td>
            <td class="px-4 py-3">
              <%= link_to 'View', house_house_room_tenant_rent_path(@house, @house_room, @tenant, rent), class: 'text-blue-600 hover:underline mr-2' %>
              <%= link_to 'Edit', edit_house_house_room_tenant_rent_path(@house, @house_room, @tenant, rent), class: 'text-yellow-600 hover:underline' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow">
      <p class="text-gray-400 mb-4">No rent records yet.</p>
      <%= link_to "Create First Rent", new_house_house_room_tenant_rent_path(@house, @house_room, @tenant), class: "bg-blue-600 text-white px-5 py-2 rounded" %>
    </div>
  <% end %>

  <%= link_to "&larr; Back to Tenant".html_safe, house_house_room_tenant_path(@house, @house_room, @tenant), class: "mt-4 inline-block text-blue-600 hover:underline" %>
</div>
