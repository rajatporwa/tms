<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Rents", path: house_house_room_tenant_rents_path(@house, @house_room, @tenant) },
    { name: @rent.month }
  ]) %>
<% end %>

<div class="max-w-2xl mx-auto mt-6 space-y-6">
  <div class="bg-white rounded-xl shadow p-6">
    <div class="flex justify-between items-start mb-4">
      <h2 class="text-2xl font-bold">Rent Record &mdash; <%= @tenant.full_name %></h2>
      <span class="px-3 py-1 rounded-full text-sm font-semibold
        <%= @rent.status == 'paid' ? 'bg-green-100 text-green-700' : @rent.status == 'partial' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
        <%= @rent.status.capitalize %>
      </span>
    </div>

    <table class="min-w-full divide-y divide-gray-200">
      <tbody class="divide-y divide-gray-100">
        <tr><td class="py-2 pr-4 font-semibold text-gray-600 w-48">Month</td><td class="py-2"><%= @rent.month %></td></tr>
        <tr><td class="py-2 pr-4 font-semibold text-gray-600">Rent Amount</td><td class="py-2">&#8377;<%= @rent.rent_amount %></td></tr>
        <tr><td class="py-2 pr-4 font-semibold text-gray-600">Electricity Share</td><td class="py-2">&#8377;<%= @rent.electricity_share %></td></tr>
        <tr><td class="py-2 pr-4 font-semibold text-gray-600">Total Amount</td><td class="py-2 font-bold">&#8377;<%= @rent.total_amount %></td></tr>
        <tr><td class="py-2 pr-4 font-semibold text-gray-600">Paid Amount</td><td class="py-2 text-green-600">&#8377;<%= @rent.paid_amount %></td></tr>
        <tr><td class="py-2 pr-4 font-semibold text-gray-600">Due Amount</td><td class="py-2 text-red-600 font-semibold">&#8377;<%= @rent.due_amount %></td></tr>
      </tbody>
    </table>

    <div class="flex flex-wrap gap-3 mt-6">
      <%= link_to "Add Payment",
            new_house_house_room_tenant_rent_payment_path(@house, @house_room, @tenant, @rent),
            class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>

      <!-- WhatsApp Send Button -->
      <a href="<%= @rent.whatsapp_url %>" target="_blank"
         class="inline-flex items-center gap-2 bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.557 4.117 1.535 5.845L0 24l6.31-1.518A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm6.093 16.407c-.26.731-1.286 1.337-2.095 1.51-.563.117-1.298.211-3.77-.81-3.167-1.292-5.21-4.513-5.37-4.72-.154-.207-1.25-1.664-1.25-3.17 0-1.503.786-2.243 1.065-2.548.278-.306.608-.382.81-.382.206 0 .41.002.59.01.189.01.443-.072.694.531.26.624.882 2.147.96 2.305.077.157.127.34.026.548-.1.207-.15.336-.296.516-.147.18-.31.403-.443.541-.147.152-.3.315-.13.617.172.303.762 1.254 1.634 2.031 1.12 1.002 2.065 1.312 2.376 1.462.31.15.492.126.673-.075.182-.202.764-.893 .967-1.2.204-.305.407-.254.685-.152.278.101 1.764.831 2.065.982.3.15.5.226.573.352.073.126.073.726-.187 1.457z"/>
        </svg>
        Send via WhatsApp
      </a>

      <!-- WhatsApp Message Preview -->
      <button onclick="document.getElementById('wa-preview').classList.toggle('hidden')"
              class="border border-gray-300 text-gray-600 px-4 py-2 rounded hover:bg-gray-50">
        Preview Message
      </button>
    </div>

    <!-- WhatsApp Message Preview Box -->
    <div id="wa-preview" class="hidden mt-4 bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-xs text-gray-500 mb-2 font-semibold">WhatsApp Message Preview:</p>
      <pre class="text-sm whitespace-pre-wrap text-gray-700"><%= @rent.whatsapp_message %></pre>
    </div>
  </div>

  <!-- Payments for this rent -->
  <div class="bg-white rounded-xl shadow p-6">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-bold">Payments</h3>
      <%= link_to "+ Add Payment",
            new_house_house_room_tenant_rent_payment_path(@house, @house_room, @tenant, @rent),
            class: "text-blue-600 hover:underline text-sm" %>
    </div>
    <% if @rent.payments.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50"><tr>
          <th class="px-3 py-2 text-left text-sm">Date</th>
          <th class="px-3 py-2 text-right text-sm">Amount</th>
          <th class="px-3 py-2 text-left text-sm">Mode</th>
          <th class="px-3 py-2 text-left text-sm">Note</th>
        </tr></thead>
        <tbody class="divide-y divide-gray-100">
          <% @rent.payments.order(payment_date: :desc).each do |p| %>
            <tr>
              <td class="px-3 py-2"><%= p.payment_date %></td>
              <td class="px-3 py-2 text-right font-semibold">&#8377;<%= p.amount %></td>
              <td class="px-3 py-2"><%= p.payment_mode %></td>
              <td class="px-3 py-2 text-gray-500"><%= p.note %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-gray-400 text-sm">No payments yet.</p>
    <% end %>
  </div>

  <div class="flex gap-4">
    <%= link_to "Edit Rent", edit_house_house_room_tenant_rent_path(@house, @house_room, @tenant, @rent), class: "text-yellow-600 hover:underline" %>
    <%= link_to "&larr; All Rents".html_safe, house_house_room_tenant_rents_path(@house, @house_room, @tenant), class: "text-blue-600 hover:underline" %>
  </div>
</div>

