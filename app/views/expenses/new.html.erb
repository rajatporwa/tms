<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Log Property Expense" }
  ]) %>
<% end %>

<div class="max-w-3xl mx-auto py-8 text-left">
  <div class="bg-white shadow-xl shadow-red-900/5 rounded-3xl border border-gray-100">
    <div class="bg-gradient-to-r from-red-600 to-orange-500 px-8 py-6 mb-8">
      <h2 class="text-2xl font-bold text-white flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Log Property Expense
      </h2>
      <p class="text-red-100 text-sm mt-1 ml-9">Record a new expense for <%= @house.house_name %></p>
    </div>

    <%= form_with(model: [@house, @expense], local: true, class: "px-8 pb-8") do |f| %>
      <% if @expense.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-8 text-sm">
          <p class="font-bold mb-1">Please fix the following errors:</p>
          <ul class="list-disc list-inside">
            <% @expense.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div>
          <%= f.label :expense_type, "Expense Category", class: "block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5 ml-1" %>
          <%= f.select :expense_type, ["Maintenance", "Electricity", "Water", "Cleaning", "Tax", "Other"], {include_blank: "Select Category"}, class: "w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-red-500 bg-white" %>
        </div>
        <div>
          <%= f.label :expense_date, "Date of Expense", class: "block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5 ml-1" %>
          <%= f.date_field :expense_date, class: "w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-red-500" %>
        </div>
      </div>

      <div class="mb-8">
        <%= f.label :amount, "Expense Amount (₹)", class: "block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5 ml-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="text-gray-500 font-bold sm:text-sm">₹</span>
          </div>
          <%= f.number_field :amount, step: "0.01", min: "0", placeholder: "0.00", class: "w-full pl-8 pr-4 py-4 border border-gray-300 rounded-xl text-lg font-black text-gray-900 focus:ring-2 focus:ring-red-500 transition-colors" %>
        </div>
      </div>

      <div class="mb-8">
        <%= f.label :description, "Note / Description", class: "block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5 ml-1" %>
        <%= f.text_area :description, rows: 4, placeholder: "Why was this expense made?", class: "w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-red-500" %>
      </div>

      <div class="mt-8 flex flex-col md:flex-row items-center gap-4 border-t border-gray-100 pt-8">
        <%= f.submit "Save Expense", class: "w-full md:w-auto px-12 py-4 bg-red-600 text-white rounded-2xl font-black text-lg shadow-lg shadow-red-200 hover:bg-red-700 hover:shadow-xl transition-all cursor-pointer" %>
        <%= link_to "Cancel", house_path(@house), class: "w-full md:w-auto px-8 py-4 text-center text-gray-500 font-bold hover:text-gray-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
