<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Overall Payment History" }
  ]) %>
<% end %>

<div class="max-w-5xl mx-auto mt-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Overall Payment History &mdash; <%= @tenant.full_name %></h2>
      <p class="text-sm text-gray-500">
        Review all payments recorded across all monthly bills for this tenant.
      </p>
    </div>
  </div>

  <!-- Summary Box -->
  <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-6 mb-6 flex flex-col md:flex-row justify-between items-center shadow-sm">
    <div class="flex items-center gap-4">
      <div class="bg-indigo-100 text-indigo-600 p-3 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <p class="text-indigo-800 text-sm font-semibold uppercase tracking-wider">Total Amount Due</p>
        <p class="text-3xl font-black text-indigo-900">₹<%= @net_due %></p>
        <%= link_to "View All Monthly Bills", house_house_room_tenant_monthly_bills_path(@house, @house_room, @tenant), class: "text-indigo-600 hover:text-indigo-800 text-sm underline font-medium mt-1 inline-block" %>
      </div>
    </div>
    <div class="mt-4 md:mt-0">
      <%= link_to "+ Add Payment", new_house_house_room_tenant_payment_path(@house, @house_room, @tenant), class: "bg-indigo-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-indigo-700 transition shadow-md inline-flex items-center" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
    <% if @payments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Mode</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Mapped to Bill</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Note</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @payments.each do |payment| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">
                  <%= payment.payment_date.strftime("%d %b %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-green-600 font-bold">
                  ₹<%= payment.amount %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 capitalize">
                  <%= payment.payment_mode %>
                  <% if payment.transaction_id.present? %>
                    <br><span class="text-xs text-gray-400">Ref: <%= payment.transaction_id %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% if payment.monthly_bill %>
                    <%= link_to "#{Date::MONTHNAMES[payment.monthly_bill.month]} #{payment.monthly_bill.year}", house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant, payment.monthly_bill), class: "text-blue-600 hover:underline" %>
                  <% elsif payment.rent %>
                    <span class="text-gray-400">Legacy Rent</span>
                  <% else %>
                    <span class="text-gray-400">-</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500 truncate max-w-[200px]" title="<%= payment.note %>">
                  <%= payment.note.presence || '-' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to "Delete", house_house_room_tenant_payment_path(@house, @house_room, @tenant, payment), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p>No payment records found for this tenant.</p>
      </div>
    <% end %>
  </div>

  <%= link_to "&larr; Back to Tenant".html_safe, house_house_room_tenant_path(@house, @house_room, @tenant), class: "mt-4 inline-block text-blue-600 hover:underline font-medium" %>
</div>
