<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Monthly Bills" }
  ]) %>
<% end %>

<div class="max-w-4xl mx-auto mt-6">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h2 class="text-2xl font-bold">Monthly Bills &mdash; <%= @tenant.full_name %></h2>
      <p class="text-gray-500">Room <%= @house_room.room_number %>, <%= @house.house_name %></p>
    </div>
    <%= link_to "Add New Bill",
          new_house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant),
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <% if @monthly_bills.any? %>
    <table class="min-w-full bg-white rounded-xl shadow divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Month/Year</th>
          <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Rent</th>
          <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Utilities</th>
          <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Total</th>
          <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">Paid</th>
          <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700">Status</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @monthly_bills.each do |bill| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= Date::MONTHNAMES[bill.month] %> <%= bill.year %></td>
            <td class="px-4 py-3 text-right">&#8377;<%= bill.rent_amount %></td>
            <td class="px-4 py-3 text-right">&#8377;<%= bill.utility_amount || 0 %></td>
            <td class="px-4 py-3 text-right font-semibold">&#8377;<%= bill.total_amount || 0 %></td>
            <td class="px-4 py-3 text-right">&#8377;<%= bill.paid_amount || 0 %></td>
            <td class="px-4 py-3 text-center">
              <span class="px-2 py-1 rounded text-xs font-semibold
                <%= bill.status == 'paid' ? 'bg-green-100 text-green-700' : bill.status == 'partial' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
                <%= bill.status&.capitalize || 'Pending' %>
              </span>
            </td>
            <td class="px-4 py-3">
              <%= link_to "View", house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant, bill), class: "text-blue-600 hover:underline mr-2" %>
              <%= link_to "Edit", edit_house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant, bill), class: "text-yellow-600 hover:underline" %>
              <% if bill.status != 'paid' %>
                <%= link_to "Pay", new_house_house_room_tenant_monthly_bill_payment_path(@house, @house_room, @tenant, bill), class: "bg-blue-600 text-white px-3 py-1.5 rounded text-xs hover:bg-blue-700 ml-2 shadow-sm font-medium transition" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow">
      <p class="text-gray-400 mb-4">No bills yet.</p>
      <%= link_to "Create First Bill",
            new_house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant),
            class: "bg-blue-600 text-white px-5 py-2 rounded" %>
    </div>
  <% end %>

  <%= link_to "&larr; Back to Tenant".html_safe, house_house_room_tenant_path(@house, @house_room, @tenant), class: "mt-4 inline-block text-blue-600 hover:underline" %>
</div>