<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name, path: house_house_room_tenant_path(@house, @house_room, @tenant) },
    { name: "Monthly Bills", path: house_house_room_tenant_monthly_bills_path(@house, @house_room, @tenant) },
    { name: "#{Date::MONTHNAMES[@monthly_bill.month]} #{@monthly_bill.year}" }
  ]) %>
<% end %>

<div class="max-w-4xl mx-auto space-y-6">

  <div class="bg-white shadow rounded p-6">
    <h2 class="text-xl font-bold mb-4">Bill Summary</h2>

    <div class="grid grid-cols-2 gap-4">
      <p><b>Rent:</b> ₹<%= @monthly_bill.rent_amount %></p>
      <p><b>Utility:</b> ₹<%= @monthly_bill.utility_amount %></p>
      <p><b>Maintenance:</b> ₹<%= @monthly_bill.maintenance_amount %></p>
      <p class="text-lg font-bold">
        Total: ₹<%= @monthly_bill.total_amount %>
      </p>
      <p><b>Paid:</b> ₹<%= @monthly_bill.paid_amount %></p>
      <p>
        <b>Status:</b>
        <span class="px-3 py-1 rounded text-white
          <%= @monthly_bill.status == "paid" ? "bg-green-500" : "bg-red-500" %>">
          <%= @monthly_bill.status.capitalize %>
        </span>
      </p>
    </div>
  </div>

  <div class="flex flex-wrap gap-3 justify-center">
    <%= link_to "Add Utility",
      new_house_house_room_tenant_monthly_bill_utility_bill_path(@house, @house_room, @tenant, @monthly_bill),
      class: "bg-indigo-500 text-white px-4 py-2 rounded" %>

    <%= link_to "View Utility Bills",
      house_house_room_tenant_monthly_bill_utility_bills_path(@house, @house_room, @tenant, @monthly_bill),
      class: "bg-blue-500 text-white px-4 py-2 rounded" %>

    <%= link_to "Edit Bill",
      edit_house_house_room_tenant_monthly_bill_path(@house, @house_room, @tenant, @monthly_bill),
      class: "bg-yellow-500 text-white px-4 py-2 rounded" %>

    <%= link_to "\u2190 Back to Bills",
      house_house_room_tenant_monthly_bills_path(@house, @house_room, @tenant),
      class: "bg-gray-500 text-white px-4 py-2 rounded" %>
  </div>

</div>
