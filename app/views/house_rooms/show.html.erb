<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}" }
  ]) %>
<% end %>

<% current_tenant = @tenants.last %>

<div class="max-w-5xl mx-auto py-6">
  
  <!-- Back navigation & Header -->
  <div class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
    <div>
      <div class="flex items-center mb-3">
        <%= link_to house_path(@house), class: "inline-flex items-center text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg px-3 py-1.5 hover:bg-gray-50 hover:text-blue-600 transition shadow-sm" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to <%= @house.house_name %>
        <% end %>
      </div>
      <h2 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
        Room <%= @house_room.room_number %>
        <% if @active_tenant.present? %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-semibold bg-red-100 text-red-700">Occupied</span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-semibold bg-green-100 text-green-700">Vacant</span>
        <% end %>
      </h2>
    </div>

    <div class="flex gap-2">
      <%= link_to edit_house_house_room_path(@house, @house_room), class: "inline-flex items-center bg-white text-gray-700 border border-gray-300 px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
        Edit Room Setting
      <% end %>

      <%= button_to house_house_room_path(@house, @house_room), method: :delete, data: { turbo_confirm: "Are you sure you want to delete Room #{@house_room.room_number} and all of its history?" }, class: "inline-flex items-center bg-white text-red-600 border border-red-200 px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-red-50 hover:border-red-300 transition-colors shadow-sm cursor-pointer" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        Delete Room
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    
    <!-- Left Column: Tenant Status & Main Actions -->
    <div class="lg:col-span-2 space-y-6">
      
      <% if @active_tenant.present? %>
        <!-- Active Tenant Dashboard -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-6 py-4 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-white flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              Current Tenant
            </h3>
            <%= link_to house_house_room_tenant_path(@house, @house_room, current_tenant), class: "text-blue-100 hover:text-white text-sm font-medium flex items-center" do %>
              View Full Profile
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>
          </div>
          
          <div class="p-6">
            <div class="flex flex-col sm:flex-row gap-6 items-start sm:items-center">
              <div class="bg-blue-100 text-blue-700 h-16 w-16 rounded-full flex items-center justify-center text-2xl font-bold shadow-inner flex-shrink-0">
                <%= current_tenant.full_name[0].upcase %>
              </div>
              
              <div class="flex-1">
                <h4 class="text-2xl font-bold text-gray-900"><%= current_tenant.full_name %></h4>
                <div class="mt-2 flex flex-wrap gap-4 text-sm text-gray-600">
                  <span class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <%= current_tenant.mobile %>
                  </span>
                  <span class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Move in: <%= current_tenant.rent_start_date %>
                  </span>
                  <% if current_tenant.tenant_partners.any? %>
                    <span class="flex items-center text-blue-600 font-medium">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                      <%= current_tenant.tenant_partners.size %> Partners
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          
          <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex flex-wrap gap-3">
            <%= link_to house_house_room_tenant_monthly_bills_path(@house, @house_room, current_tenant), class: "inline-flex items-center px-4 py-2 bg-indigo-600 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white hover:bg-indigo-700 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              All Monthly Bills
            <% end %>

            <%= link_to house_house_room_tenant_payments_path(@house, @house_room, current_tenant), class: "inline-flex items-center px-4 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 8h6m-5 0a3 3 0 110 6H9l3 3m-3-6h6m6 1a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Payment History
            <% end %>
            

          </div>
        </div>
      <% else %>
        <!-- Vacant State -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 border-dashed border-2 p-12 text-center">
          <div class="mx-auto h-20 w-20 bg-green-50 text-green-500 rounded-full flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 3z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-2">Room is Vacant</h3>
          <p class="text-gray-500 mb-8 max-w-md mx-auto">This room is currently empty and generating ₹0. Add a tenant to start tracking rent and utility bills.</p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <%= link_to new_house_house_room_tenant_path(@house, @house_room), class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-xl shadow-md text-white bg-green-600 hover:bg-green-700 transition w-full sm:w-auto justify-center" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
              </svg>
              Assign New Tenant
            <% end %>

            <% last_past_tenant = @tenants.find { |t| t.status == 'vacated' || t.status == 'inactive' } %>
            <% if last_past_tenant.present? %>
              <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-left w-full sm:w-auto">
                <span class="text-[10px] font-black uppercase tracking-widest text-gray-400 block mb-1">Last Occupied By</span>
                <div class="flex items-center gap-2">
                  <span class="text-sm font-bold text-gray-700"><%= last_past_tenant.full_name %></span>
                  <span class="text-[10px] text-gray-500 font-medium italic">(Left: <%= last_past_tenant.updated_at.strftime("%d %b '%y") %>)</span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>

    <!-- Right Column: Room Details Sidebar -->
    <div class="space-y-6">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-3">Room Information</h3>
        <dl class="space-y-4">
          <div class="flex justify-between items-center">
            <dt class="text-sm font-medium text-gray-500">Base Rent</dt>
            <dd class="text-lg font-bold text-gray-900">₹<%= @house_room.rent %></dd>
          </div>
          <div class="flex justify-between items-center">
            <dt class="text-sm font-medium text-gray-500">Room Status</dt>
            <dd class="text-sm font-semibold capitalize <%= current_tenant.present? ? 'text-red-600' : 'text-green-600' %>">
              <%= current_tenant.present? ? 'Occupied' : 'Vacant' %>
            </dd>
          </div>
        </dl>
      </div>
    </div>
    
  </div>

  <!-- Monthly Bills & Rent History Table -->
  <% if current_tenant.present? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-8">
      <div class="px-6 py-5 border-b border-gray-200 flex justify-between items-center bg-gray-50/50">
        <h3 class="text-lg font-bold text-gray-900">Current Tenant Billing & Rent</h3>
        <%= link_to new_house_house_room_tenant_monthly_bill_path(@house, @house_room, current_tenant), class: "inline-flex items-center text-sm font-medium text-white bg-indigo-600 rounded-lg shadow-sm px-4 py-2 hover:bg-indigo-700 transition duration-150" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Generate New Bill
        <% end %>
      </div>

      <% if current_tenant.monthly_bills.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-white">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Month-Year</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Rent</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider text-blue-600">Electricity</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider text-blue-400">Water</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Maint.</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider text-purple-600">Other</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider text-red-500">Prev. Dues</th>
                <th class="px-4 py-3 text-right text-xs font-bold text-gray-800 uppercase tracking-wider">Total Due</th>
                <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Dates</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <% [current_tenant.monthly_bills.includes(:utility_bills).order(year: :desc, month: :desc).first].compact.each do |bill| %>
                <% 
                   elec = bill.utility_bills.find { |u| u.utility_type&.downcase == 'electricity' }&.amount || 0
                   water = bill.utility_bills.find { |u| u.utility_type&.downcase == 'water' }&.amount || 0
                   other = bill.utility_bills.reject { |u| ['electricity', 'water'].include?(u.utility_type&.downcase) }.sum(&:amount)
                   global_billed = current_tenant.monthly_bills.sum(:total_amount)
                   global_paid = current_tenant.payments.sum(:amount)
                   true_net_due = global_billed - global_paid
                   
                   bill_unpaid = bill.total_amount - (bill.paid_amount || 0)
                   prev_dues = true_net_due - bill_unpaid
                   total_with_dues = true_net_due
                %>
                <tr class="hover:bg-gray-50 transition cursor-pointer" onclick="window.location='<%= house_house_room_tenant_monthly_bill_path(@house, @house_room, current_tenant, bill) %>'">
                  <td class="px-4 py-4 whitespace-nowrap">
                    <div class="font-bold text-gray-900"><%= Date::MONTHNAMES[bill.month] %> <%= bill.year %></div>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-gray-600 font-medium">₹<%= bill.rent_amount %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-blue-600 font-medium">₹<%= elec %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-blue-400 font-medium">₹<%= water %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-gray-600 font-medium">₹<%= bill.maintenance_amount || 0 %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-purple-600 font-medium">₹<%= other %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-red-500 font-medium">₹<%= prev_dues %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-gray-900 font-black">₹<%= total_with_dues %></td>
                  <td class="px-4 py-4 whitespace-nowrap text-center">
                    <% if true_net_due <= 0 %>
                      <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-green-100 text-green-800 border border-green-200">Clear</span>
                    <% else %>
                      <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-red-100 text-red-800 border border-red-200">Dues Pending</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500 flex flex-col gap-0.5">
                    <span class="text-xs"><span class="text-gray-400">Due:</span> <%= bill.due_date&.strftime('%d %b %Y') || 'N/A' %></span>
                    <% if ['paid', 'partial'].include?(bill.status) %>
                      <span class="text-xs text-green-600"><span class="text-gray-400">Paid On:</span> <%= bill.updated_at.strftime('%d %b') %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="flex items-center justify-end">
                      <% if true_net_due > 0 %>
                        <%= link_to new_house_house_room_tenant_payment_path(@house, @house_room, current_tenant), class: "inline-flex items-center text-white bg-green-600 hover:bg-green-700 shadow-sm px-3 py-1.5 rounded text-xs font-medium mr-2 transition-colors", data: { turbo: false } do %>
                          Pay Dues
                        <% end %>
                      <% end %>
                      <%= link_to house_house_room_tenant_monthly_bill_payments_path(@house, @house_room, current_tenant, bill), class: "inline-flex items-center text-purple-700 bg-purple-100 hover:bg-purple-200 px-2.5 py-1.5 rounded text-xs font-semibold mr-2 transition" do %>
                        History
                      <% end %>
                      <%= link_to house_house_room_tenant_monthly_bill_path(@house, @house_room, current_tenant, bill), class: "inline-flex items-center text-blue-700 bg-blue-100 hover:bg-blue-200 px-2.5 py-1.5 rounded text-xs font-semibold transition" do %>
                        Details
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-12 text-center text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <p>No monthly bills generated yet. Click 'Generate New Bill' to start.</p>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Tenant History Table -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200 flex justify-between items-center bg-gray-50/50">
      <h3 class="text-lg font-bold text-gray-900">Tenant History</h3>
    </div>

    <% if @tenants.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-white">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Tenant Name</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Contact</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Start Date</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @tenants.each do |tenant| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="font-medium text-gray-900"><%= tenant.full_name %></div>
                  <% if tenant == current_tenant %>
                    <span class="text-xs text-blue-600 font-semibold mt-0.5 inline-block">Current</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= tenant.mobile %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= tenant.rent_start_date %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if tenant == current_tenant %>
                    <span class="px-2.5 py-1 inline-flex text-[10px] leading-5 font-black uppercase tracking-widest rounded-full bg-green-100 text-green-800">
                      Active
                    </span>
                  <% else %>
                    <span class="px-2.5 py-1 inline-flex text-[10px] leading-5 font-black uppercase tracking-widest rounded-full bg-gray-100 text-gray-800">
                      <%= tenant.status.presence || 'Past' %>
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to house_house_room_tenant_path(@house, @house_room, tenant), class: "inline-flex text-blue-700 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-md text-xs font-bold transition" do %>
                      View Profile
                    <% end %>
                    <%= link_to edit_house_house_room_tenant_path(@house, @house_room, tenant), class: "inline-flex text-gray-700 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-md text-xs font-bold transition" do %>
                      Edit
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
