<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: "Tenants" }
  ]) %>
<% end %>

<div class="max-w-5xl mx-auto mt-6">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold">Tenants — Room <%= @house_room.room_number %></h2>
    <%= link_to "Add Tenant", new_house_house_room_tenant_path(@house, @house_room),
          class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <% if @tenants.any? %>
    <div class="grid gap-4">
      <% @tenants.each do |tenant| %>
        <div class="bg-white rounded-xl shadow p-4 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <% if tenant.profile_photo.attached? %>
              <%= image_tag tenant.profile_photo, class: "w-14 h-14 rounded-full object-cover" %>
            <% else %>
              <div class="w-14 h-14 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">N/A</div>
            <% end %>
            <div>
              <p class="font-semibold text-lg"><%= tenant.full_name %></p>
              <p class="text-gray-500 text-sm"><%= tenant.mobile %></p>
            </div>
          </div>
          <div class="flex gap-3">
            <%= link_to "View", house_house_room_tenant_path(@house, @house_room, tenant), class: "text-blue-600 hover:underline" %>
            <%= link_to "Edit", edit_house_house_room_tenant_path(@house, @house_room, tenant), class: "text-yellow-600 hover:underline" %>
            <%= button_to "Remove", house_house_room_tenant_path(@house, @house_room, tenant), method: :delete,
                  data: { confirm: "Remove this tenant?" }, class: "text-red-600 hover:underline bg-transparent border-0 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-xl shadow">
      <p class="text-gray-400 mb-4">No tenants in this room yet.</p>
      <%= link_to "Add First Tenant", new_house_house_room_tenant_path(@house, @house_room), class: "bg-blue-600 text-white px-5 py-2 rounded" %>
    </div>
  <% end %>

  <%= link_to "← Back to Room", house_house_room_path(@house, @house_room), class: "mt-4 inline-block text-blue-600 hover:underline" %>
</div>
