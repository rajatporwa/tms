<% content_for :breadcrumbs do %>
  <%= breadcrumbs([
    { name: "Houses", path: houses_path },
    { name: @house.house_name, path: house_path(@house) },
    { name: "Room #{@house_room.room_number}", path: house_house_room_path(@house, @house_room) },
    { name: @tenant.full_name }
  ]) %>
<% end %>

<div class="max-w-5xl mx-auto py-8">

  <%# ── Action Bar ── %>
  <div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <%= link_to house_house_room_path(@house, @house_room), class: "inline-flex items-center text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg px-4 py-2 hover:bg-gray-50 hover:text-blue-600 transition shadow-sm" do %>
      <svg style="width:16px;height:16px;margin-right:6px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Back to Room Dashboard
    <% end %>
    <div class="flex gap-3">
      <%= link_to edit_house_house_room_tenant_path(@house, @house_room, @tenant), class: "inline-flex items-center px-4 py-2 bg-white border border-gray-300 rounded-xl shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" do %>
        <svg style="width:15px;height:15px;margin-right:6px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit Profile
      <% end %>
      <%= link_to new_house_house_room_tenant_tenant_partner_path(@house, @house_room, @tenant), class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white rounded-xl shadow-sm text-sm font-bold hover:bg-indigo-700 transition" do %>
        <svg style="width:15px;height:15px;margin-right:6px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
        Add Partner
      <% end %>
    </div>
  </div>

  <%# ══════════════════════════════════════ %>
  <%# PRIMARY TENANT CARD                   %>
  <%# ══════════════════════════════════════ %>
  <div class="bg-white rounded-3xl shadow-sm border border-gray-200 mb-8 overflow-hidden">
    <div class="h-2 bg-gradient-to-r from-indigo-500 via-purple-500 to-blue-500"></div>
    <div class="p-6 md:p-8">

      <%# ── Top: Avatar + Name + Status ── %>
      <div class="flex items-start gap-4 pb-4 border-b border-gray-100 mb-5">
        <%# Avatar %>
        <div class="flex-shrink-0">
          <% if @tenant.profile_photo.attached? %>
            <%= image_tag @tenant.profile_photo, class: "w-16 h-16 rounded-xl object-cover border-2 border-white shadow-md ring-2 ring-indigo-100" %>
          <% else %>
            <div class="w-16 h-16 rounded-xl bg-indigo-50 border-2 border-indigo-100 text-indigo-600 flex items-center justify-center text-2xl font-black shadow-sm">
              <%= @tenant.first_name[0].upcase %>
            </div>
          <% end %>
        </div>

        <%# Name + Room + Mobiles %>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="text-xl font-black text-gray-900 leading-tight"><%= @tenant.full_name %></h2>
              <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mt-0.5">Room <%= @house_room.room_number %> &bull; Primary Tenant</p>
            </div>
            <span class="px-3 py-1.5 rounded-xl text-xs font-black uppercase tracking-widest shadow-sm border flex-shrink-0 mt-0.5 <%= @tenant.status == 'active' ? 'bg-green-50 text-green-700 border-green-200' : 'bg-red-50 text-red-600 border-red-200' %>">
              ● &nbsp;<%= @tenant.status %>
            </span>
          </div>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="inline-flex items-center gap-1 bg-gray-50 border border-gray-200 rounded-lg px-2.5 py-1 text-xs font-semibold text-gray-700">
              <svg style="width:12px;height:12px;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <%= @tenant.mobile %>
            </span>
            <% if @tenant.alternate_mobile.present? %>
              <span class="inline-flex items-center gap-1 bg-gray-50 border border-gray-200 rounded-lg px-2.5 py-1 text-xs font-semibold text-gray-700">
                <svg style="width:12px;height:12px;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <%= @tenant.alternate_mobile %>
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Details Grid (compact) ── %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-3 mb-5">
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Date of Birth</p>
          <p class="text-xs font-bold text-gray-900"><%= @tenant.dob.present? ? @tenant.dob.strftime("%d %b %Y") : '—' %></p>
        </div>
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Gender</p>
          <p class="text-xs font-bold text-gray-900 capitalize"><%= @tenant.gender.presence || '—' %></p>
        </div>
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Occupation</p>
          <p class="text-xs font-bold text-gray-900 capitalize"><%= @tenant.occupation.presence || '—' %></p>
        </div>
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Rent Start</p>
          <p class="text-xs font-bold text-gray-900"><%= @tenant.rent_start_date.present? ? @tenant.rent_start_date.strftime("%d %b %Y") : '—' %></p>
        </div>
        <div>
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Father / Guardian</p>
          <p class="text-xs font-bold text-gray-900"><%= @tenant.father_name.presence || '—' %></p>
        </div>
        <div class="col-span-3">
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-0.5">Permanent Address</p>
          <p class="text-xs font-bold text-gray-900 leading-snug"><%= @tenant.permanent_address.presence || '—' %></p>
        </div>
      </div>

      <%# ── Vehicles (inline pills, compact) ── %>
      <% if @tenant.vehicles.any? %>
        <div class="border-t border-gray-100 pt-4 mb-4">
          <p class="text-[9px] font-black text-blue-500 uppercase tracking-widest mb-2">Vehicles (<%= @tenant.vehicles.count %>)</p>
          <div class="flex flex-wrap gap-2">
            <% @tenant.vehicles.each do |vehicle| %>
              <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-xl px-3 py-2">
                <div class="w-7 h-7 rounded-lg bg-white border border-blue-100 flex items-center justify-center text-blue-600 shadow-sm" style="min-width:28px">
                  <% if vehicle.vehicle_type == "4 Wheeler" %>
                    <svg style="width:16px;height:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
                  <% else %>
                    <svg style="width:16px;height:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><path d="M9 17h6"/><path d="M13 14h-5l-2-4h8l-1 4Z"/><path d="M14 7l1 2"/><path d="M9 7l-1 2"/><path d="M15 15l1-3h3l-2 3Z"/></svg>
                  <% end %>
                </div>
                <div>
                  <p class="text-[10px] font-black text-gray-800 uppercase leading-none"><%= vehicle.vehicle_name.presence || 'Vehicle' %></p>
                  <p class="text-[9px] font-bold text-blue-400 uppercase"><%= vehicle.vehicle_type %></p>
                </div>
                <span class="text-[10px] font-black font-mono text-blue-700 bg-white border border-blue-100 rounded-lg px-2 py-0.5 tracking-wider uppercase shadow-sm"><%= vehicle.vehicle_no %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# ── Identity Document ── %>
      <% if @tenant.document_file.attached? || @tenant.document_type.present? %>
        <div class="border-t border-gray-100 pt-5">
          <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">Identity Document</p>
          <div class="inline-flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-200 hover:border-indigo-300 transition group max-w-xs">
            <div class="p-2 bg-white rounded-lg shadow-sm text-indigo-500" style="flex-shrink:0">
              <svg style="width:18px;height:18px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-black text-gray-900 uppercase"><%= @tenant.document_type.presence || "ID CARD" %></p>
              <p class="text-xs font-mono text-gray-500 mt-0.5 truncate"><%= @tenant.document_number.presence || '——' %></p>
            </div>
            <% if @tenant.document_file.attached? %>
              <%= link_to url_for(@tenant.document_file), target: "_blank", class: "w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center justify-center text-indigo-500 hover:bg-indigo-500 hover:text-white hover:border-indigo-500 transition shadow-sm" do %>
                <svg style="width:14px;height:14px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

  <%# ══════════════════════════════════════ %>
  <%# PARTNER CARDS                         %>
  <%# ══════════════════════════════════════ %>
  <% if @tenant.tenant_partners.any? %>
    <div>
      <div class="flex items-center gap-3 mb-5">
        <h3 class="text-lg font-black text-gray-900">Living Partners</h3>
        <span class="bg-indigo-100 text-indigo-700 text-xs font-black px-2.5 py-1 rounded-full"><%= @tenant.tenant_partners.size %></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <% @tenant.tenant_partners.each_with_index do |partner, idx| %>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:border-indigo-200 hover:shadow-md transition-all duration-300">
            <div class="h-1.5 bg-gradient-to-r from-purple-400 to-indigo-400"></div>
            <div class="p-5">

              <%# Partner header %>
              <div class="flex items-center gap-3 mb-4">
                <% if partner.profile_photo.attached? %>
                  <%= image_tag partner.profile_photo, class: "w-12 h-12 rounded-xl object-cover border border-indigo-100 shadow-sm flex-shrink-0" %>
                <% else %>
                  <div class="w-12 h-12 rounded-xl bg-indigo-50 border border-indigo-100 text-indigo-600 flex items-center justify-center text-xl font-black flex-shrink-0">
                    <%= partner.first_name[0].upcase %>
                  </div>
                <% end %>
                <div class="flex-1 min-w-0">
                  <h4 class="text-base font-black text-gray-900 leading-tight"><%= partner.first_name %> <%= partner.last_name %></h4>
                  <div class="flex flex-wrap gap-1.5 mt-1">
                    <% if partner.gender.present? %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest bg-indigo-50 text-indigo-600 border border-indigo-100"><%= partner.gender %></span>
                    <% end %>
                    <% if partner.occupation.present? %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest bg-gray-50 text-gray-600 border border-gray-200"><%= partner.occupation %></span>
                    <% end %>
                    <% if partner.dob.present? %>
                      <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest bg-amber-50 text-amber-600 border border-amber-100"><%= partner.dob.strftime("%d %b %Y") %></span>
                    <% end %>
                  </div>
                </div>
                <span class="text-[11px] font-black text-gray-300 uppercase tracking-widest flex-shrink-0">#<%= idx + 1 %></span>
              </div>

              <%# Info pills row %>
              <div class="flex flex-col gap-2 mb-3">
                <% if partner.mobile.present? %>
                  <div class="flex items-center gap-2 text-sm font-semibold text-gray-700 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2">
                    <svg style="width:14px;height:14px;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    <span><%= partner.mobile %></span>
                  </div>
                <% end %>
                <% if partner.father_name.present? %>
                  <div class="flex items-center gap-2 text-sm font-semibold text-gray-700 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2">
                    <svg style="width:14px;height:14px;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <span class="text-gray-500 text-xs font-bold mr-1">Father:</span><span><%= partner.father_name %></span>
                  </div>
                <% end %>
                <% if partner.permanent_address.present? %>
                  <div class="flex items-start gap-2 text-sm font-semibold text-gray-700 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2">
                    <svg style="width:14px;height:14px;flex-shrink:0;margin-top:2px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="leading-snug"><%= partner.permanent_address %></span>
                  </div>
                <% end %>
              </div>

              <% if partner.document_file.attached? %>
                <%= link_to url_for(partner.document_file), target: "_blank", class: "flex items-center justify-center w-full px-4 py-2 border border-indigo-100 text-xs font-black uppercase tracking-wider rounded-xl text-indigo-600 bg-indigo-50/50 hover:bg-indigo-600 hover:text-white transition-all duration-200" do %>
                  <svg style="width:14px;height:14px;margin-right:6px;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  View <%= partner.document_type.presence || "ID Proof" %>
                <% end %>
              <% end %>

            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl border border-dashed border-gray-200 p-8 text-center">
      <div class="w-12 h-12 bg-indigo-50 rounded-full flex items-center justify-center mx-auto mb-3">
        <svg style="width:24px;height:24px" class="text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
      </div>
      <p class="text-gray-500 font-semibold text-sm">No partners added yet.</p>
      <%= link_to new_house_house_room_tenant_tenant_partner_path(@house, @house_room, @tenant), class: "inline-flex items-center mt-3 text-sm font-bold text-indigo-600 hover:text-indigo-800 transition" do %>
        + Add Living Partner
      <% end %>
    </div>
  <% end %>

</div>
